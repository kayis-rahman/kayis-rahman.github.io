---
layout: null
---
[{% for post in site.posts %}{"id":{{ forloop.index }},"title":{{ post.title | jsonify }},"url":{{ post.url | relative_url | jsonify }},"date":{{ post.date | date: '%B %d, %Y' | jsonify }},"tags":{{ post.tags | join: ', ' | jsonify }},"excerpt":{{ post.excerpt | strip_html | normalize_whitespace | truncate: 300 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
